LINE_CHANNEL_ACCESS_TOKEN=put_your_channel_access_token_here

# Either set LINE_TO for push messages, or set LINE_BROADCAST=true.
# LINE_TO is a userId or groupId from the LINE Messaging API.
LINE_TO=
LINE_BROADCAST=false

# Optional overrides
CHECK_INTERVAL_MS=300000
DEPARTURE_DATE=2026-07-23
ADULTS=2
STATE_FILE=state/availability-state.json
NOTIFY_EVERY_AVAILABLE=false
